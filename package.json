{
  "name": "matt-token",
  "version": "1.0.0",
  "private": true,
  "description": "Official open-source contracts and website for MATT on Ronin.",
  "license": "MIT",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "node scripts/run-contract-tests.js",
    "coverage": "hardhat coverage",
    "deploy:saigon": "hardhat deploy --network saigon --tags MattToken",
    "deploy:ronin": "hardhat deploy --network ronin --tags MattToken",
    "deploy:coinflip:saigon": "hardhat deploy --network saigon --tags MattCoinFlip",
    "deploy:coinflip:ronin": "hardhat deploy --network ronin --tags MattCoinFlip",
    "deploy:coinflip-burn:saigon": "hardhat deploy --network saigon --tags MattCoinFlipBurn",
    "deploy:coinflip-burn:ronin": "hardhat deploy --network ronin --tags MattCoinFlipBurn",
    "deploy:rewards:saigon": "hardhat deploy --network saigon --tags MattDailyRewards",
    "deploy:rewards:ronin": "hardhat deploy --network ronin --tags MattDailyRewards",
    "deploy:rewards-v2:saigon": "hardhat deploy --network saigon --tags MattDailyRewardsV2",
    "deploy:rewards-v2:ronin": "hardhat deploy --network ronin --tags MattDailyRewardsV2",
    "deploy:blackjack:saigon": "hardhat run scripts/deploy-blackjack-vault.js --network saigon",
    "deploy:blackjack:ronin": "hardhat run scripts/deploy-blackjack-vault.js --network ronin",
    "deploy:flappy:ronin": "hardhat run scripts/deploy-flappy-matt-prize-pool.js --network ronin",
    "inspect:flappy:ronin": "hardhat run scripts/inspect-flappy-matt-prize-pool.js --network ronin",
    "set-operator:flappy:ronin": "hardhat run scripts/set-flappy-matt-operator.js --network ronin",
    "test:flappy": "hardhat test test/FlappyMattPrizePool.test.js && node website/lib/flappy-matt-engine.test.js && node website/lib/flappy-matt-settlement.test.js",
    "verify:saigon": "hardhat sourcify --endpoint https://sourcify.roninchain.com/server/ --network saigon",
    "verify:ronin": "hardhat sourcify --endpoint https://sourcify.roninchain.com/server/ --network ronin",
    "site": "node website/crash-live-server.js",
    "inspect:saigon": "hardhat run scripts/inspect-deployment.js --network saigon",
    "inspect:ronin": "hardhat run scripts/inspect-deployment.js --network ronin",
    "inspect:coinflip:saigon": "hardhat run scripts/inspect-coin-flip.js --network saigon",
    "inspect:coinflip:ronin": "hardhat run scripts/inspect-coin-flip.js --network ronin",
    "inspect:coinflip-burn:saigon": "hardhat run scripts/inspect-coin-flip-burn.js --network saigon",
    "inspect:coinflip-burn:ronin": "hardhat run scripts/inspect-coin-flip-burn.js --network ronin",
    "inspect:rewards:saigon": "hardhat run scripts/inspect-daily-rewards.js --network saigon",
    "inspect:rewards:ronin": "hardhat run scripts/inspect-daily-rewards.js --network ronin",
    "inspect:rewards-v2:saigon": "hardhat run scripts/inspect-daily-rewards-v2.js --network saigon",
    "inspect:rewards-v2:ronin": "hardhat run scripts/inspect-daily-rewards-v2.js --network ronin"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.4.0",
    "dotenv": "^16.4.7",
    "hardhat": "^2.26.3",
    "hardhat-deploy": "^0.12.4",
    "solc": "^0.8.28"
  },
  "dependencies": {
    "express": "^5.1.0"
  }
}
